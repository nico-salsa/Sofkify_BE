								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Customer-Id",
								"value": "{{customer_id}}",
								"description": "ID del cliente"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productId\": \"{{product_id_1}}\",\n  \"quantity\": 2\n}"
